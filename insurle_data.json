    {
      "id": "contract_auto",
      "name": "AutoGuard Vehicle Insurance",
      "type": "Vehicle Insurance",
      "insurer": "AutoGuard Insurance Co.",
      "policy_number": "AG-VH-2024-001",
      "effective_date": "2024-01-01",
      "expiry_date": "2024-12-31",
      "premium": "$1,200/year",
      "coverage": "$50,000",
      "icon": "\ud83d\ude97",
      "color": "#1a3a5c",
      "accent": "#e8b84b",
      "contract_text": [
        "SECTION 1 \u2013 ELIGIBILITY: The insured driver must be at least 21 years of age at the time of the incident.",
        "SECTION 2 \u2013 VEHICLE OWNERSHIP: Coverage applies only when the insured is operating a vehicle they legally own or have explicit written permission to operate.",
        "SECTION 3 \u2013 SOBRIETY REQUIREMENT: Any claim arising from an incident where the driver's blood alcohol content (BAC) exceeded 0.08% at the time of the incident shall be deemed invalid and coverage will be denied.",
        "SECTION 4 \u2013 VALID LICENSE: The driver must hold a valid, unexpired driver's license issued by a recognized authority.",
        "SECTION 5 \u2013 INCIDENT REPORTING: Claims must be reported within 30 days of the incident date.",
        "SECTION 6 \u2013 GEOGRAPHICAL SCOPE: Coverage is limited to incidents occurring within the continental United States.",
        "SECTION 7 \u2013 VEHICLE TYPE: Coverage applies to personal passenger vehicles only. Commercial vehicles, motorcycles, and off-road vehicles are excluded.",
        "SECTION 8 \u2013 FRAUD: Any misrepresentation of facts in the claim submission will result in immediate denial and possible legal action."
      ],
      "insurle_rules": [
        "%% AutoGuard Vehicle Insurance \u2014 InsurLE Contract Rules",
        "%% Policy: AG-VH-2024-001",
        "",
        "%% A claim is valid if ALL conditions are satisfied",
        "valid_claim(C) :-",
        "    age_eligible(C),",
        "    owns_or_permitted_vehicle(C),",
        "    sober_at_incident(C),",
        "    valid_license(C),",
        "    reported_in_time(C),",
        "    incident_in_coverage_zone(C),",
        "    covered_vehicle_type(C).",
        "",
        "%% Section 1: Age must be >= 21",
        "age_eligible(C) :-",
        "    age(C, A),",
        "    A >= 21.",
        "",
        "%% Section 2: Vehicle ownership or written permission",
        "owns_or_permitted_vehicle(C) :-",
        "    vehicle_ownership(C, own).",
        "owns_or_permitted_vehicle(C) :-",
        "    vehicle_ownership(C, permitted),",
        "    has_written_permission(C, true).",
        "",
        "%% Section 3: BAC must be <= 0.08",
        "sober_at_incident(C) :-",
        "    bac(C, BAC),",
        "    BAC =< 0.08.",
        "",
        "%% Section 4: License must be valid and not expired",
        "valid_license(C) :-",
        "    license_valid(C, true),",
        "    license_expired(C, false).",
        "",
        "%% Section 5: Reported within 30 days",
        "reported_in_time(C) :-",
        "    days_since_incident(C, D),",
        "    D =< 30.",
        "",
        "%% Section 6: Must be in continental US",
        "incident_in_coverage_zone(C) :-",
        "    incident_location(C, continental_us).",
        "",
        "%% Section 7: Personal passenger vehicle only",
        "covered_vehicle_type(C) :-",
        "    vehicle_type(C, passenger)."
      ],
      "claim_count": 3,
      "valid_count": 1,
      "invalid_count": 2
    },
    {
      "id": "contract_health",
      "name": "VitalCare Health Insurance",
      "type": "Health Insurance",
      "insurer": "VitalCare Health Group",
      "policy_number": "VC-HLT-2024-087",
      "effective_date": "2024-01-01",
      "expiry_date": "2024-12-31",
      "premium": "$450/month",
      "coverage": "$500,000 lifetime",
      "icon": "\ud83c\udfe5",
      "color": "#1a4a3a",
      "accent": "#4ecb8d",
      "contract_text": [
        "SECTION 1 \u2013 ENROLLMENT: The policyholder must have been continuously enrolled for a minimum of 90 days before filing any non-emergency claim.",
        "SECTION 2 \u2013 PRE-EXISTING CONDITIONS: Conditions diagnosed prior to the enrollment date are covered only after a 12-month waiting period from the enrollment date.",
        "SECTION 3 \u2013 NETWORK PROVIDERS: Claims are covered at 100% for in-network providers and 60% for out-of-network providers. Emergency services are covered regardless of network status.",
        "SECTION 4 \u2013 AUTHORIZATION: Non-emergency procedures exceeding $5,000 require prior written authorization from VitalCare.",
        "SECTION 5 \u2013 DEDUCTIBLE: An annual deductible of $1,500 must be met before claims are processed. Emergency claims bypass the deductible.",
        "SECTION 6 \u2013 LIFETIME MAXIMUM: Total lifetime benefits shall not exceed $500,000 per policyholder.",
        "SECTION 7 \u2013 COSMETIC PROCEDURES: Purely cosmetic procedures with no medical necessity are excluded from coverage.",
        "SECTION 8 \u2013 CLAIM SUBMISSION: Claims must be submitted within 180 days of the date of service."
      ],
      "insurle_rules": [
        "%% VitalCare Health Insurance \u2014 InsurLE Contract Rules",
        "%% Policy: VC-HLT-2024-087",
        "",
        "valid_claim(C) :-",
        "    enrollment_satisfied(C),",
        "    pre_existing_waiting_satisfied(C),",
        "    authorized_if_needed(C),",
        "    not_cosmetic_only(C),",
        "    within_lifetime_max(C),",
        "    submitted_in_time(C).",
        "",
        "%% Section 1: 90 days enrollment minimum",
        "enrollment_satisfied(C) :-",
        "    is_emergency(C, true).",
        "enrollment_satisfied(C) :-",
        "    days_enrolled(C, D),",
        "    D >= 90.",
        "",
        "%% Section 2: Pre-existing condition waiting period",
        "pre_existing_waiting_satisfied(C) :-",
        "    pre_existing_condition(C, false).",
        "pre_existing_waiting_satisfied(C) :-",
        "    pre_existing_condition(C, true),",
        "    months_since_enrollment(C, M),",
        "    M >= 12.",
        "",
        "%% Section 3 & 4: Authorization for large non-emergency procedures",
        "authorized_if_needed(C) :-",
        "    is_emergency(C, true).",
        "authorized_if_needed(C) :-",
        "    claim_amount(C, A),",
        "    A =< 5000.",
        "authorized_if_needed(C) :-",
        "    claim_amount(C, A),",
        "    A > 5000,",
        "    prior_authorization(C, true).",
        "",
        "%% Section 7: Not purely cosmetic",
        "not_cosmetic_only(C) :-",
        "    cosmetic_only(C, false).",
        "not_cosmetic_only(C) :-",
        "    cosmetic_only(C, true),",
        "    medical_necessity(C, true).",
        "",
        "%% Section 6: Within lifetime maximum",
        "within_lifetime_max(C) :-",
        "    cumulative_claims(C, Total),",
        "    Total =< 500000.",
        "",
        "%% Section 8: Within 180 days",
        "submitted_in_time(C) :-",
        "    days_since_service(C, D),",
        "    D =< 180."
      ],
      "claim_count": 3,
      "valid_count": 1,
      "invalid_count": 2
