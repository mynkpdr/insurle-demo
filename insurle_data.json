    {
      "id": "contract_travel",
      "name": "JetSafe Travel Insurance",
      "type": "Travel Insurance",
      "insurer": "JetSafe Global Underwriters",
      "policy_number": "JS-TRV-2024-445",
      "effective_date": "2024-01-01",
      "expiry_date": "2024-12-31",
      "premium": "$85/trip",
      "coverage": "$100,000 per trip",
      "icon": "\u2708\ufe0f",
      "color": "#2a1a5c",
      "accent": "#a78bfa",
      "contract_text": [
        "SECTION 1 \u2013 TRIP PURCHASE: The policy must be purchased within 21 days of the initial trip deposit.",
        "SECTION 2 \u2013 CANCELLATION COVERAGE: Trip cancellation benefits are payable only for covered reasons including: illness, injury, death of insured or immediate family member, natural disaster, or airline bankruptcy.",
        "SECTION 3 \u2013 PRE-TRIP HEALTH: The insured must be medically fit to travel at the time the policy is purchased. Claims arising from conditions known at purchase time are excluded.",
        "SECTION 4 \u2013 ADVENTURE ACTIVITIES: Injuries sustained during extreme sports (skydiving, BASE jumping, free solo climbing) are excluded unless the Adventure Rider has been purchased.",
        "SECTION 5 \u2013 BAGGAGE: Lost or stolen baggage claims require a police report filed within 24 hours of discovery. Maximum baggage claim is $2,500.",
        "SECTION 6 \u2013 DOCUMENTATION: All claims must be accompanied by original receipts, invoices, or official documentation.",
        "SECTION 7 \u2013 ALCOHOL/DRUGS: Claims arising from incidents where the insured was under the influence of alcohol or unprescribed drugs are excluded.",
        "SECTION 8 \u2013 WAR EXCLUSION: Claims arising from acts of war, terrorism, or civil unrest are excluded."
      ],
      "insurle_rules": [
        "%% JetSafe Travel Insurance \u2014 InsurLE Contract Rules",
        "%% Policy: JS-TRV-2024-445",
        "",
        "valid_claim(C) :-",
        "    policy_purchased_in_time(C),",
        "    covered_cancellation_reason(C),",
        "    medically_fit_at_purchase(C),",
        "    adventure_covered(C),",
        "    baggage_reported_timely(C),",
        "    has_documentation(C),",
        "    not_under_influence(C),",
        "    not_war_related(C).",
        "",
        "%% Section 1: Purchased within 21 days of deposit",
        "policy_purchased_in_time(C) :-",
        "    days_after_deposit(C, D),",
        "    D =< 21.",
        "",
        "%% Section 2: Covered cancellation reason",
        "covered_cancellation_reason(C) :-",
        "    claim_type(C, Type),",
        "    Type \\= trip_cancellation.",
        "covered_cancellation_reason(C) :-",
        "    claim_type(C, trip_cancellation),",
        "    cancellation_reason(C, Reason),",
        "    member(Reason, [illness, injury, death, natural_disaster, airline_bankruptcy]).",
        "",
        "%% Section 4: Adventure sports coverage",
        "adventure_covered(C) :-",
        "    activity(C, Activity),",
        "    \\+ member(Activity, [skydiving, base_jumping, free_solo_climbing]).",
        "adventure_covered(C) :-",
        "    activity(C, Activity),",
        "    member(Activity, [skydiving, base_jumping, free_solo_climbing]),",
        "    adventure_rider(C, true).",
        "",
        "%% Section 5: Baggage police report",
        "baggage_reported_timely(C) :-",
        "    claim_type(C, Type),",
        "    Type \\= baggage.",
        "baggage_reported_timely(C) :-",
        "    claim_type(C, baggage),",
        "    hours_to_report(C, H),",
        "    H =< 24.",
        "",
        "%% Section 6: Has documentation",
        "has_documentation(C) :-",
        "    documentation_provided(C, true).",
        "",
        "%% Section 7: Not under influence",
        "not_under_influence(C) :-",
        "    under_influence(C, false).",
        "",
        "%% Section 8: Not war related",
        "not_war_related(C) :-",
        "    war_related(C, false)."
      ],
