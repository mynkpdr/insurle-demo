    {
      "id": "contract_accident",
      "name": "ShieldPlus Personal Accident",
      "type": "Accident Insurance",
      "insurer": "ShieldPlus Casualty Ltd.",
      "policy_number": "SP-ACC-2024-209",
      "effective_date": "2024-01-01",
      "expiry_date": "2024-12-31",
      "premium": "$180/year",
      "coverage": "$250,000",
      "icon": "\ud83d\udee1\ufe0f",
      "color": "#4a1a1a",
      "accent": "#f87171",
      "contract_text": [
        "SECTION 1 \u2013 ACCIDENTAL DEATH & DISMEMBERMENT: Full benefit payable upon accidental death or loss of two limbs/eyes. 50% benefit for loss of one limb or eye.",
        "SECTION 2 \u2013 TEMPORARY TOTAL DISABILITY: Weekly benefit of $500 for up to 52 weeks when the insured is completely unable to work due to a covered accident.",
        "SECTION 3 \u2013 AGE LIMITS: Coverage applies to individuals between ages 18 and 70 at time of accident.",
        "SECTION 4 \u2013 EXCLUSIONS: Benefits are not payable for accidents resulting from: self-inflicted injuries, participation in criminal activity, war or military operations, professional sports activities.",
        "SECTION 5 \u2013 SUBSTANCE EXCLUSION: No benefit is payable if the accident occurred while the insured was intoxicated or under the influence of non-prescribed substances.",
        "SECTION 6 \u2013 CLAIM NOTIFICATION: Accidental death claims must be notified within 30 days. Disability claims must be notified within 14 days of commencement of disability.",
        "SECTION 7 \u2013 MEDICAL EVIDENCE: All claims require supporting medical evidence from a licensed physician. Self-reported injuries without medical documentation are not covered.",
        "SECTION 8 \u2013 OCCUPATION: Claims arising from hazardous occupational activities are subject to additional review and may require supplemental premium payment."
      ],
      "insurle_rules": [
        "%% ShieldPlus Personal Accident \u2014 InsurLE Contract Rules",
        "%% Policy: SP-ACC-2024-209",
        "",
        "valid_claim(C) :-",
        "    age_in_range(C),",
        "    not_excluded_cause(C),",
        "    sober_at_accident(C),",
        "    notified_in_time(C),",
        "    has_medical_evidence(C).",
        "",
        "%% Section 3: Age between 18 and 70",
        "age_in_range(C) :-",
        "    age(C, A),",
        "    A >= 18,",
        "    A =< 70.",
        "",
        "%% Section 4: Not an excluded cause",
        "not_excluded_cause(C) :-",
        "    cause(C, Cause),",
        "    \\+ member(Cause, [self_inflicted, criminal_activity, war, professional_sports]).",
        "",
        "%% Section 5: Sober at time of accident",
        "sober_at_accident(C) :-",
        "    intoxicated(C, false).",
        "",
        "%% Section 6: Notification time",
        "notified_in_time(C) :-",
        "    claim_type(C, accidental_death),",
        "    days_to_notify(C, D),",
        "    D =< 30.",
        "notified_in_time(C) :-",
        "    claim_type(C, disability),",
        "    days_to_notify(C, D),",
        "    D =< 14.",
        "",
        "%% Section 7: Medical evidence required",
        "has_medical_evidence(C) :-",
        "    medical_evidence(C, true)."
      ],
      "claim_count": 2,
      "valid_count": 1,
      "invalid_count": 1
    }
